# ── Supabase ──────────────────────────────────────────────────────────────────

# Your Supabase project URL
# Found at: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key — used for pgvector chunk retrieval and hint cache
# Found at: Supabase Dashboard → Settings → API → anon public
SUPABASE_ANON_KEY=

# Supabase service_role key — used for hint cache writes and chunk embedding
# Found at: Supabase Dashboard → Settings → API → service_role (KEEP SECRET)
SUPABASE_SERVICE_KEY=

# ── Internal Auth ─────────────────────────────────────────────────────────────

# Shared secret between proxy-layer and hint services
# Must match INTERNAL_TOKEN in proxy-layer exactly
# Generate with: openssl rand -hex 32
INTERNAL_TOKEN=your-random-64-char-hex-string-here
