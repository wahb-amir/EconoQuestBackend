# ── Supabase ──────────────────────────────────────────────────────────────────

# Your Supabase project URL
# Found at: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service_role key — used for JWT verification (auth.getUser) and cache writes
# Found at: Supabase Dashboard → Settings → API → service_role (KEEP SECRET)
# IMPORTANT: Must be pasted as a single line with no newlines or trailing spaces
SUPABASE_SERVICE_KEY=...

# ── Internal Auth ─────────────────────────────────────────────────────────────

# Shared secret for internal service-to-service calls (/internal/* endpoints)
# Must match INTERNAL_TOKEN in hint-service and summary-service exactly
# Generate with: openssl rand -hex 32
INTERNAL_TOKEN=your-random-64-char-hex-string-here

# Supabase JWT secret — used by @fastify/jwt plugin (if enabled)
# Found at: Supabase Dashboard → Settings → API → JWT Secret
JWT_SECRET=your-supabase-jwt-secret-here

# ── HuggingFace Space URLs ────────────────────────────────────────────────────

# Hint service instances (load balanced)
HF_HINT_SPACE_1=https://your-hf-username-hint-service-1.hf.space
HF_HINT_SPACE_2=https://your-hf-username-hint-service-2.hf.space

# Summary service instances (load balanced)
HF_SUMMARY_SPACE_1=https://your-hf-username-summary-1.hf.space
HF_SUMMARY_SPACE_2=https://your-hf-username-summary-2.hf.space

# Auth service (used for health cron ping)
AUTH_SERVICE_URL=https://your-hf-username-auth-service.hf.space
