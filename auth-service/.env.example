# ── Supabase ──────────────────────────────────────────────────────────────────

# Your Supabase project URL
# Found at: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — used for sign_in_with_password and OAuth
# Found at: Supabase Dashboard → Settings → API → anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service_role key — used for admin.create_user and upsert_score RPC
# Found at: Supabase Dashboard → Settings → API → service_role (KEEP SECRET)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── CORS ─────────────────────────────────────────────────────────────────────

# Frontend origin — must match exactly (no trailing slash)
# This is the only origin allowed to send credentialed requests
FRONTEND_URL=https://econoquest.wahb.space
